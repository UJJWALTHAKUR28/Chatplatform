# =============================================================
#  Ember Chat Platform — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# =============================================================

# ── Django Core ───────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-CHANGE-ME-IN-PRODUCTION-use-50-random-chars

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
# Production example: yourdomain.com,www.yourdomain.com,yourapp.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ─────────────────────────────────────
# Local:    postgresql://USER:PASSWORD@localhost:5432/ember_db
# Supabase: postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres
#           Use session-mode pooler (port 5432) — required for Django ORM.
#           Transaction-mode / pgbouncer (port 6543) breaks prepared statements.
# Railway:  Automatically set via $DATABASE_URL variable in Railway dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── Redis ─────────────────────────────────────────────────────
# Used by Django Channels (WebSocket layer) and caching.
# Local:    redis://localhost:6379/0
# Upstash:  rediss://:TOKEN@HOST.upstash.io:6379
# Railway:  rediss://:TOKEN@HOST:6379
# Leave blank to fall back to InMemoryChannelLayer (single-worker only, not for production).
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Development: http://localhost:3000
# Production:  https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── JWT Authentication (djangorestframework-simplejwt) ────────
# simplejwt signs tokens with Django's SECRET_KEY above — no
# separate JWT_SECRET_KEY is needed.
# Uncomment below to override the lifetime defaults in settings.py:
# ACCESS_TOKEN_LIFETIME_MINUTES=15
# REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Message Encryption (Fernet AES-128-CBC + HMAC-SHA256) ─────
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: NEVER rotate this key without re-encrypting all stored messages first.
#          Losing this key means all messages become permanently unreadable.
MESSAGE_ENCRYPTION_KEY=GENERATE_A_FERNET_KEY_AND_PUT_IT_HERE

