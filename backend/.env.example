# ── Django Core ──────────────────────────────────────────────
SECRET_KEY=django-insecure-CHANGE-ME-IN-PRODUCTION-use-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL / Supabase) ─────────────────────────
# Using session-mode pooler (port 5432) — required for Django ORM.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── Redis ────────────────────────────────────────────────────
# Standard Redis:   redis://localhost:6379/0
# Upstash TLS:      rediss://:TOKEN@HOST:6379
# Leave blank to fall back to InMemoryChannelLayer (single-worker only)
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────
# ACCESS_TOKEN_LIFETIME_MINUTES=15
# REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Message Encryption (Fernet AES) ──────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Never rotate this key without re-encrypting all stored messages first.
MESSAGE_ENCRYPTION_KEY=GENERATE_A_KEY_AND_PUT_IT_HERE
