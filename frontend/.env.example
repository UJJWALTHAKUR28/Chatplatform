# =============================================================
#  Ember Chat Platform — Frontend Environment Variables
#  Copy this file to .env.local and fill in your values.
# =============================================================

# ── Backend API ───────────────────────────────────────────────
# Base URL for the Django REST API (no trailing slash).
# Development: http://localhost:8000/api/v1
# Production:  https://yourapp.up.railway.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── WebSocket ─────────────────────────────────────────────────
# Base URL for the Django Channels WebSocket server (no trailing slash).
# Development: ws://localhost:8000/ws
# Production:  wss://yourapp.up.railway.app/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
